modules = ["python-3.11"]
run = "python3 bot.py"
[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot"

[[workflows.workflow]]
name = "Discord Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python bot.py"
waitForPort = 5000

[deployment]
deploymentTarget = "gce"
run = ["sh", "-c", "python bot.py"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

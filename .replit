modules = ["python-3.11", "postgresql-16"]
run = "python3 bot.py"
[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Bot & Landing Page"

[[workflows.workflow]]
name = "Bot & Landing Page"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python start.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "vm"
run = ["gunicorn", "app:app", "--bind", "0.0.0.0:5000", "--workers", "2", "--timeout", "120"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 37819
externalPort = 3000

[[ports]]
localPort = 38193
externalPort = 6800

[[ports]]
localPort = 38503
externalPort = 3001

[[ports]]
localPort = 39991
externalPort = 5000

[[ports]]
localPort = 40409
externalPort = 3002

[[ports]]
localPort = 43799
externalPort = 6000

[[ports]]
localPort = 44191
externalPort = 5173

[[ports]]
localPort = 44297
externalPort = 3003

[[ports]]
localPort = 45355
externalPort = 4200

[agent]
expertMode = true
integrations = ["flask_stripe:1.0.0", "replitmail:1.0.0"]

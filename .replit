modules = ["python-3.11", "postgresql-16"]
run = "python3 bot.py"
[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot"

[[workflows.workflow]]
name = "Discord Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python bot.py"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["python", "bot.py"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 36757
externalPort = 3003

[[ports]]
localPort = 37819
externalPort = 3000

[[ports]]
localPort = 38503
externalPort = 3001

[[ports]]
localPort = 40409
externalPort = 3002

[[ports]]
localPort = 40865
externalPort = 5000

[[ports]]
localPort = 44191
externalPort = 5173

[[ports]]
localPort = 45355
externalPort = 4200

[agent]
expertMode = true
integrations = ["flask_stripe:1.0.0"]
